PORT=3000

# SAP
SAP_BASE_URL=https://your-sap-instance.com/api
SAP_CLIENT_ID=<sap_client_id>
SAP_CLIENT_SECRET=<sap_client_secret>

# TOTVS Protheus
TOTVS_BASE_URL=http://your-totvs-instance:8080/rest
TOTVS_USER=<totvs_user>
TOTVS_PASSWORD=<totvs_password>

# Omie
OMIE_BASE_URL=https://app.omie.com.br/api/v1
OMIE_APP_KEY=<omie_app_key>
OMIE_APP_SECRET=<omie_app_secret>

# Bling
BLING_BASE_URL=https://www.bling.com.br/Api/v3
BLING_API_KEY=<bling_api_key>

# ERP ativo: sap | totvs | omie | bling
ACTIVE_ERP=omie
